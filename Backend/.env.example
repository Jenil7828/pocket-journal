# Secrets and credentials only — all other configuration is in Backend/config.yml
# Copy this file to .env and fill in your actual secret values

# Firebase
FIREBASE_CREDENTIALS_PATH=secrets/filename.json
FIREBASE_WEB_API_KEY=your_firebase_web_api_key_here

# Google AI / Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# TMDB (Movie Database)
TMDB_API_KEY=your_tmdb_api_key_here

# Spotify
SONG_ID=your_spotify_client_id_here
SONG_SECRET=your_spotify_client_secret_here

# Google Books
GOOGLE_BOOKS_API_KEY=your_google_books_api_key_here

# Podcast API (if applicable)
PODCAST_API_KEY=your_podcast_api_key_here

