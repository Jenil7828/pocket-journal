# .env.gcs — GCP Production
# Copy to Backend/.env for GCP deployment

MODEL_SOURCE=gcs
MODEL_GCS_BUCKET=pocket-journal-models
MODEL_CACHE_DIR=/tmp/models
MODEL_DOWNLOAD_ON_STARTUP=true

# Model versions
MODEL_ROBERTA_VERSION=v2
MODEL_BART_VERSION=v2
MODEL_QWEN2_VERSION=v1

# Firebase (or use GCP service account)
FIREBASE_CREDENTIALS_PATH=/app/secrets/firebase.json

# GCS authentication — container must have credentials via:
# - Workload Identity (GKE recommended)
# - Service account JSON mounted at /var/secrets/google/
# - GOOGLE_APPLICATION_CREDENTIALS env var

# Other configs as needed...

