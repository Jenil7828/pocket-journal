# Exclude git and metadata
.git
.gitignore

# Python caches and bytecode
__pycache__/
*.py[cod]
*$py.class
.pytest_cache
*/__pycache__

# Virtual environment directories
.venv/
venv/
env/
ENV/

# Distribution/build directories
build/
dist/
*.egg-info/
pip-wheel-metadata/

# Editor and IDE files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db

# Test artifacts and caches
.pytest_cache/
testing_api/
test_reports/

# Environment / secrets
.env
Backend/*.json

# Model outputs and training artifacts (we exclude training outputs except for
# the inference models directory which must be present locally and included in
# the runtime image). The `!` lines re-include the models directory.
Backend/Mood_Detection/outputs/
Backend/Mood_Detection/mood_detection_roberta/*.pt
Backend/Mood_Detection/mood_detection_roberta/*.bin
!Backend/Mood_Detection/outputs/models
!Backend/Mood_Detection/outputs/models/**

# Explicitly exclude training scripts and large datasets; keep inference/summarization code
Backend/Mood_Detection/mood_detection_roberta/train.py
Backend/Mood_Detection/mood_detection_roberta/trainer.py
Backend/Mood_Detection/mood_detection_roberta/evaluator.py
Backend/Mood_Detection/mood_detection_roberta/dataset_loader.py
Backend/Mood_Detection/data/
Backend/Mood_Detection/analysis/

# Misc
*.log
